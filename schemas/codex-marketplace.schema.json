{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "metadata", "owner", "plugins"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string" },
    "metadata": {
      "type": "object",
      "required": ["description", "version"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "homepage": { "type": "string", "pattern": "^https?://.+" }
      }
    },
    "owner": {
      "type": "object",
      "required": ["name", "github"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "github": { "type": "string" }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description", "source", "category"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "source": {
            "type": "object",
            "oneOf": [
              {
                "required": ["source", "url"],
                "additionalProperties": false,
                "properties": {
                  "source": { "type": "string", "enum": ["url"] },
                  "url": {
                    "type": "string",
                    "pattern": "^https://github\\.com/.+\\.git$"
                  },
                  "ref": { "type": "string" }
                }
              },
              {
                "required": ["source", "repo"],
                "additionalProperties": false,
                "properties": {
                  "source": { "type": "string", "enum": ["github"] },
                  "repo": {
                    "type": "string",
                    "pattern": "^[^/]+/[^/]+$"
                  },
                  "ref": { "type": "string" }
                }
              }
            ]
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "category": {
            "type": "string",
            "enum": [
              "productivity",
              "execution",
              "security",
              "testing",
              "documentation",
              "utilities",
              "memory"
            ]
          },
          "keywords": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
