#!/usr/bin/env bash
set -euo pipefail

SOCK="$HOME/.orbstack/run/docker.sock"
STAMP="$HOME/.local/share/orb-autostop/last_active"
IDLE_THRESHOLD=$(( 15 * 60 ))

_ping() {
  curl -sf --unix-socket "$SOCK" http://localhost/_ping &>/dev/null
}

_has_running_containers() {
  curl -sf --unix-socket "$SOCK" http://localhost/containers/json \
    | jq -e '[.[] | select(.State == "running")] | length > 0' &>/dev/null
}

_has_socket_clients() {
  lsof -U 2>/dev/null \
    | grep "$SOCK" \
    | grep -qvE 'OrbStack|orbctl|vmgr|com\.docker'
}

_has_dev_server() {
  lsof -iTCP:3000-9000 -sTCP:LISTEN -n -P 2>/dev/null \
    | grep -qv '^COMMAND'
}

# Bail if OrbStack isn't running
_ping || exit 0

mkdir -p "$(dirname "$STAMP")"

if _has_running_containers || _has_socket_clients || _has_dev_server; then
  date +%s > "$STAMP"
  exit 0
fi

last=$(cat "$STAMP" 2>/dev/null || date +%s | tee "$STAMP")
now=$(date +%s)
idle=$(( now - last ))

if [[ $idle -ge $IDLE_THRESHOLD ]]; then
  logger -t orb-autostop "Idle for ${idle}s - stopping OrbStack"
  orbctl stop &>/dev/null
fi
